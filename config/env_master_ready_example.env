# network-thesis .env pavyzdys po master-ready pataisų
# Saugus numatytasis režimas: ChatGPT/OpenAI API nekviečiamas be vienkartinio leidimo.

# Vietinis Ollama LLM. Raspberry Pi 5 su qwen2.5:7b gali generuoti labai ilgai, todėl timeout valdomas čia.
export LOCAL_LLM_ENABLED=0
export LOCAL_LLM_MODEL="qwen2.5:7b-instruct"
export LOCAL_LLM_TIMEOUT=3600
export LOCAL_LLM_MAX_INPUT_BYTES=12000
export LOCAL_LLM_MAX_PROMPT_BYTES=18000
export LOCAL_LLM_HARD_PROMPT_LIMIT_BYTES=26000

# PDF ir el. pašto pristatymas per full_assessment.py
export RECOMMENDATION_DELIVERY_ENABLED=1
export EMAIL_SEND_ENABLED=1
export SMTP_HOST="smtp.gmail.com"
export SMTP_PORT="587"
export SMTP_USER="jusu_pastas@example.com"
export SMTP_PASSWORD="ĮRAŠYK_APP_PASSWORD_BE_TARPŲ"
export EMAIL_FROM="jusu_pastas@example.com"
export SMTP_TO="gavejas@example.com"

# Suderinamumas su nauju recommendation_delivery.py
export RECOMMENDATION_EMAIL_FROM="${RECOMMENDATION_EMAIL_FROM:-${EMAIL_FROM:-}}"
export RECOMMENDATION_EMAIL_TO="${RECOMMENDATION_EMAIL_TO:-${SMTP_TO:-}}"
export RECOMMENDATION_SMTP_HOST="${RECOMMENDATION_SMTP_HOST:-${SMTP_HOST:-}}"
export RECOMMENDATION_SMTP_PORT="${RECOMMENDATION_SMTP_PORT:-${SMTP_PORT:-}}"
export RECOMMENDATION_SMTP_USER="${RECOMMENDATION_SMTP_USER:-${SMTP_USER:-}}"
export RECOMMENDATION_SMTP_PASSWORD="${RECOMMENDATION_SMTP_PASSWORD:-${SMTP_PASSWORD:-}}"

# ChatGPT/OpenAI API. Kviečiamas tik kai tikrai reikia ir tik su vienkartiniu leidimu.
export OPENAI_API_ENABLED=1
export OPENAI_API_MODE="when_needed"
export OPENAI_API_REQUIRE_MANUAL_APPROVAL=1
export OPENAI_API_ONLY_WHEN_NEEDED=1
export OPENAI_API_SKIP_IF_EVIDENCE_UNCHANGED=1
export OPENAI_API_MAX_CALLS_PER_DAY=1
export OPENAI_API_MAX_CALLS_PER_MONTH=5
export OPENAI_API_MIN_RISK_SCORE=70
export OPENAI_API_MAX_INPUT_CHARS=220000
export OPENAI_API_MAX_OUTPUT_TOKENS=7000
export OPENAI_API_TIMEOUT=240
export OPENAI_API_DELETE_UPLOADED_FILE=1
export OPENAI_API_KEY="ĮRAŠYK_SAVO_API_RAKTĄ"
export OPENAI_API_MODEL="gpt-4.1-mini"

# Rankinio ChatGPT paketo siuntimą galima palikti išjungtą, nes rekomendacijų PDF generuojamas automatiškai.
export CHATGPT_MANUAL_PACKAGE_DISABLED=1
export CHATGPT_PACKAGE_EMAIL_ENABLED=0

# Magistrinio darbo metrikos
# academic_experiment_metrics.py vykdomas automatiškai per full_assessment.py pabaigoje.
export ACADEMIC_METRICS_ENABLED=1

# AI metodų palyginimui naudok ai_method_experiment_runner.py.
# ChatGPT/OpenAI metodas per runnerį kviečiamas tik su --allow-chatgpt.
