# ============================================================
# NETWORK-THESIS EKSPERIMENTŲ KONFIGŪRACIJA
# ============================================================
# Keisk tik šią eilutę:
#
# 1 - bazinė taisyklinė analizė be LLM ir be el. pašto
# 2 - vietinis LLM / Ollama rekomendacijos
# 3 - ChatGPT / OpenAI API rekomendacijos
# 4 - rankinio AI įkėlimo paketas el. paštu
#
export EXPERIMENT_MODE=1


# ============================================================
# VIETINIS LLM / OLLAMA
# ============================================================

export LOCAL_LLM_MODEL=qwen2.5:7b-instruct
export LOCAL_LLM_TIMEOUT=3600
export LOCAL_LLM_MAX_INPUT_CHARS=18000
export LOCAL_LLM_HARD_INPUT_CHARS=26000


# ============================================================
# EL. PAŠTAS / GMAIL SMTP
# ============================================================

export SMTP_HOST=smtp.gmail.com
export SMTP_PORT=587
export SMTP_USER="irasyti_el_pasta"
export SMTP_PASSWORD="APP_PASS"
export EMAIL_FROM="irasyti_el_pasta"
export SMTP_TO="irasyti_el_pasta"

3
# ============================================================
# OPENAI / CHATGPT API
# ============================================================

export OPENAI_API_KEY="API_RAKTAS"
export OPENAI_API_MODEL=gpt-5.4-mini

export OPENAI_API_MAX_CALLS_PER_DAY=3
export OPENAI_API_MAX_CALLS_PER_MONTH=7
export OPENAI_API_MAX_INPUT_CHARS=220000
export OPENAI_API_MAX_OUTPUT_TOKENS=7000
export OPENAI_API_DELETE_UPLOADED_FILE=1


# ============================================================
# EKSPERIMENTO REŽIMŲ LOGIKA
# ============================================================

case "${EXPERIMENT_MODE}" in

  1)
    export LOCAL_LLM_ENABLED=0
    export OPENAI_API_ENABLED=0
    export OPENAI_API_ALLOW_RUN=0
    export OPENAI_API_MODE="off"

    export RECOMMENDATION_DELIVERY_ENABLED=0

    export EMAIL_ENABLED=0
    export EMAIL_SEND_ENABLED=0
    export CHATGPT_PACKAGE_EMAIL_ENABLED=0

    export OPENAI_API_REQUIRE_MANUAL_APPROVAL=1
    export OPENAI_API_SKIP_IF_EVIDENCE_UNCHANGED=1
    export OPENAI_API_ONLY_WHEN_NEEDED=1
    export OPENAI_API_MIN_RISK_SCORE=70
    ;;

  2)
    # 2 bandymas – vietinis LLM / Ollama
    export LOCAL_LLM_ENABLED=1

    export OPENAI_API_ENABLED=0
    export OPENAI_API_ALLOW_RUN=0
    export OPENAI_API_MODE="off"

    export RECOMMENDATION_DELIVERY_ENABLED=1

    export EMAIL_ENABLED=1
    export EMAIL_SEND_ENABLED=1
    export CHATGPT_PACKAGE_EMAIL_ENABLED=0

    export OPENAI_API_REQUIRE_MANUAL_APPROVAL=1
    export OPENAI_API_SKIP_IF_EVIDENCE_UNCHANGED=1
    export OPENAI_API_ONLY_WHEN_NEEDED=1
    export OPENAI_API_MIN_RISK_SCORE=70
    ;;

  3)
    # 3 bandymas – ChatGPT / OpenAI API
    export LOCAL_LLM_ENABLED=0

    export OPENAI_API_ENABLED=1
    export OPENAI_API_ALLOW_RUN=1
    export OPENAI_API_MODE="when_needed"

    export RECOMMENDATION_DELIVERY_ENABLED=1

    export EMAIL_ENABLED=1
    export EMAIL_SEND_ENABLED=1
    export CHATGPT_PACKAGE_EMAIL_ENABLED=0

    export OPENAI_API_REQUIRE_MANUAL_APPROVAL=1
    export OPENAI_API_SKIP_IF_EVIDENCE_UNCHANGED=0
    export OPENAI_API_ONLY_WHEN_NEEDED=0
    export OPENAI_API_MIN_RISK_SCORE=0
    ;;

  4)
    # 4 bandymas – rankinio AI įkėlimo paketas el. paštu
    export LOCAL_LLM_ENABLED=0

    export OPENAI_API_ENABLED=0
    export OPENAI_API_ALLOW_RUN=0
    export OPENAI_API_MODE="off"

    export RECOMMENDATION_DELIVERY_ENABLED=0

    export EMAIL_ENABLED=1
    export EMAIL_SEND_ENABLED=1
    export CHATGPT_PACKAGE_EMAIL_ENABLED=1

    export OPENAI_API_REQUIRE_MANUAL_APPROVAL=1
    export OPENAI_API_SKIP_IF_EVIDENCE_UNCHANGED=1
    export OPENAI_API_ONLY_WHEN_NEEDED=1
    export OPENAI_API_MIN_RISK_SCORE=70
    ;;

  *)
    echo "[KLAIDA] Netinkamas EXPERIMENT_MODE=${EXPERIMENT_MODE}. Naudok 1, 2, 3 arba 4."
    return 1 2>/dev/null || exit 1
    ;;
esac


# ============================================================
# SUDERINAMUMAS SU SKRIPTAIS
# ============================================================

export USE_RECOMMENDATION_DELIVERY="${RECOMMENDATION_DELIVERY_ENABLED}"
export USE_EMAIL_SEND="${EMAIL_SEND_ENABLED}"
export USE_CHATGPT_MANUAL_PACKAGE="${CHATGPT_PACKAGE_EMAIL_ENABLED}"
export USE_LOCAL_LLM="${LOCAL_LLM_ENABLED}"
export USE_OPENAI_API="${OPENAI_API_ENABLED}"

export RECOMMENDATION_EMAIL_FROM="${EMAIL_FROM:-}"
export RECOMMENDATION_EMAIL_TO="${SMTP_TO:-}"

export RECOMMENDATION_SMTP_HOST="${SMTP_HOST:-}"
export RECOMMENDATION_SMTP_PORT="${SMTP_PORT:-}"
export RECOMMENDATION_SMTP_USER="${SMTP_USER:-}"
export RECOMMENDATION_SMTP_PASSWORD="${SMTP_PASSWORD:-}"
